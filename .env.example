# Production must use a publicly trusted HTTPS origin. For local device testing, use the development machine's LAN HTTP origin.
EXPO_PUBLIC_API_URL=https://api.example.com

# Optional. Sentry project DSN — crash reporting is disabled (no-op) until this is set.
# Get it from your Sentry project's Settings > Client Keys (DSN).
EXPO_PUBLIC_SENTRY_DSN=
